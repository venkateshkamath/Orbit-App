PORT=8000
NODE_ENV=development

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/mindlink

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# JWT
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- OTP email ---
# Default From (must match what your provider allows)
# MAIL_FROM=ORBIT <hello@joinorbit.org>

# Option A — Resend (https://resend.com): verify your domain, then:
# RESEND_API_KEY=re_xxxxxxxx

# Option B — SMTP (Google Workspace uses smtp.gmail.com + App Password, NOT your login password)
# Create App Password: https://myaccount.google.com/apppasswords
# Test without starting the API: npm run test:smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=hello@joinorbit.org
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# MAIL_FROM=ORBIT <hello@joinorbit.org>

# Microsoft 365 example: SMTP_HOST=smtp.office365.com (use your tenant’s SMTP settings)

# Dev: include OTP in API JSON
# OTP_DEBUG_RESPONSE=false

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder
