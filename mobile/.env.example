# Production API URL (e.g., https://api.orbit.app/api)
# If signup fails with "Cannot reach the server" on a real device, set this to
# http://YOUR_LAN_IP:8000/api (same Wi‑Fi as your computer).
EXPO_PUBLIC_API_URL=
# Production WebSocket URL (e.g., wss://api.orbit.app/ws)
EXPO_PUBLIC_WS_URL=
# Google Maps (Android dev/production builds & iOS if using Google provider). Enable Maps SDK for Android/iOS in Google Cloud; restrict key by package name + SHA-1. Used at prebuild — not prefixed with EXPO_PUBLIC_.
GOOGLE_MAPS_API_KEY=
# Optional — only if you create an Expo account and use Expo’s push service: EAS_PROJECT_ID=<uuid>
